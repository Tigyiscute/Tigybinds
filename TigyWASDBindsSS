javascript:(function(){if(document.getElementById('tigy-binds-menu'))return;const m={Up:{k:'ArrowUp',c:38,d:'ArrowUp',current:'w'},Left:{k:'ArrowLeft',c:37,d:'ArrowLeft',current:'a'},Down:{k:'ArrowDown',c:40,d:'ArrowDown',current:'s'},Right:{k:'ArrowRight',c:39,d:'ArrowRight',current:'d'}};let activeListen=null;const menu=document.createElement('div');menu.id='tigy-binds-menu';menu.style=`position:fixed;top:20px;right:20px;width:240px;background:rgba(20,20,20,0.85);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.1);border-radius:12px;color:#fff;font-family:sans-serif;padding:15px;box-shadow:0 10px 30px rgba(0,0,0,0.5);z-index:999999;user-select:none;`;const title=document.createElement('div');title.innerHTML='<span style="color:#3b82f6;font-weight:bold;">Tigy</span> Key Binds';title.style='font-size:16px;margin-bottom:12px;border-bottom:1px solid rgba(255,255,255,0.1);padding-bottom:6px;display:flex;justify-content:between;';menu.appendChild(title);const container=document.createElement('div');function render(){container.innerHTML='';Object.keys(m).forEach(action=>{const row=document.createElement('div');row.style='display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;font-size:14px;';const label=document.createElement('span');label.innerText=action;const btn=document.createElement('button');btn.innerText=activeListen===action?'Press key...':m[action].current.toUpperCase();btn.style=`background:${activeListen===action?'#10b981':'rgba(255,255,255,0.1)'};border:none;color:#fff;padding:4px 10px;border-radius:6px;cursor:pointer;min-width:70px;text-align:center;font-weight:bold;transition:all 0.2s;`;btn.onclick=()=>{activeListen=action;render()};row.appendChild(label);row.appendChild(btn);container.appendChild(row)})}menu.appendChild(container);document.body.appendChild(menu);render();window.addEventListener('keydown',e=>{if(activeListen){e.preventDefault();m[activeListen].current=e.key.toLowerCase();activeListen=null;render();return}const l=e.key.toLowerCase();const action=Object.keys(m).find(k=>m[k].current===l);if(action){e.preventDefault();const canvas=document.querySelector('canvas')||document.getElementById('unity-canvas')||document;if(canvas.focus)canvas.focus();const ev=new KeyboardEvent('keydown',{key:m[action].k,keyCode:m[action].c,code:m[action].d,which:m[action].c,bubbles:true,cancelable:true});canvas.dispatchEvent(ev)}},true);window.addEventListener('keyup',e=>{const l=e.key.toLowerCase();const action=Object.keys(m).find(k=>m[k].current===l);if(action){e.preventDefault();const canvas=document.querySelector('canvas')||document.getElementById('unity-canvas')||document;const ev=new KeyboardEvent('keyup',{key:m[action].k,keyCode:m[action].c,code:m[action].d,which:m[action].c,bubbles:true,cancelable:true});canvas.dispatchEvent(ev)}},true);})();
