javascript:(function(){const m={w:{k:'ArrowUp',c:38,d:'ArrowUp'},a:{k:'ArrowLeft',c:37,d:'ArrowLeft'},s:{k:'ArrowDown',c:40,d:'ArrowDown'},d:{k:'ArrowRight',c:39,d:'ArrowRight'}};function t(e,k,targ){const ev=new KeyboardEvent(e,{key:k.k,keyCode:k.c,code:k.d,which:k.c,bubbles:true,cancelable:true});targ.dispatchEvent(ev)}window.addEventListener('keydown',function(e){if(e.key==='['){e.preventDefault();const act=prompt('Which bind to change? (w, a, s, or d):');if(m[act]){const newKey=prompt(`Press ok and type the new key for ${act.toUpperCase()}:`);if(newKey){m[newKey.toLowerCase()]=m[act];delete m[act];alert('Bind Updated!');}}return;}const l=e.key.toLowerCase();if(m[l]){e.preventDefault();const canvas=document.querySelector('canvas')||document.getElementById('unity-canvas')||document;if(canvas.focus)canvas.focus();t('keydown',m[l],canvas)}},true);window.addEventListener('keyup',function(e){const l=e.key.toLowerCase();if(m[l]){e.preventDefault();const canvas=document.querySelector('canvas')||document.getElementById('unity-canvas')||document;t('keyup',m[l],canvas)}},true);alert('WASD Binds Active! Press [ to swap binds.');})();
